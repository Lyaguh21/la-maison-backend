generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int           @id @default(autoincrement())
  name               String?
  email              String        @unique
  phone              String?       @unique
  passwordHash       String
  hashedRefreshToken String?
  tokenVersion       Int           @default(0)
  role               Role          @default(CUSTOMER)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  userAllergens      Ingredient[]  @relation("UserAllergens")
  reservations       Reservation[]
}

model Tables {
  id         Int         @id @default(autoincrement())
  number     Int         @unique
  tableType  TableType
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  floorItems FloorItems?
}

model FloorItems {
  id        Int            @id @default(autoincrement())
  type      TypeFloorItems
  tableId   Int?           @unique
  x         Int
  y         Int
  width     Int
  height    Int
  rotation  Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  table     Tables?        @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model MenuCategory {
  id     Int    @id @default(autoincrement())
  name   String @unique
  dishes Dish[]
}

model Ingredient {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  dishIngredients DishIngredient[]
  allergenUsers   User[]           @relation("UserAllergens")
}

model Dish {
  id              Int              @id @default(autoincrement())
  categoryId      Int
  name            String           @unique
  description     String?
  price           Float
  photo           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        MenuCategory     @relation(fields: [categoryId], references: [id])
  dishIngredients DishIngredient[]
  orderItems      OrderItem[]
}

model DishIngredient {
  dishId       Int
  ingredientId Int
  dish         Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([dishId, ingredientId])
}

model Reservation {
  id            Int                @id @default(autoincrement())
  userId        Int?
  user          User?              @relation(fields: [userId], references: [id])
  guestName     String?
  guestPhone    String?
  tableId       Int
  guestsCount   Int
  status        StatusReservations @default(BOOKED)
  startTime     DateTime
  endTime       DateTime
  realStartTime DateTime?
  realEndTime   DateTime?
  waiterId      Int?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  order         Order[]
}

model Order {
  id              Int         @id @default(autoincrement())
  reservationId   Int
  totalPriceOrder Float
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  finishedAt      DateTime?
  reservation     Reservation @relation(fields: [reservationId], references: [id])
  orderItems      OrderItem[]
}

model OrderItem {
  id            Int             @id @default(autoincrement())
  orderId       Int
  dishId        Int
  comment       String?
  quantity      Int
  priceSnapshot Int
  status        StatusOrderItem @default(COOKING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  dish          Dish            @relation(fields: [dishId], references: [id])
  order         Order           @relation(fields: [orderId], references: [id])
}

enum Role {
  ADMIN
  WAITER
  COOK
  CUSTOMER
}

enum TableType {
  TWO
  FOUR
  SIX
}

enum TypeFloorItems {
  TABLE
  WC
  EXIT
  BAR
}

enum StatusReservations {
  BOOKED
  SEATED
  CANCELLED
  PAID
  COMPLETED
  NO_SHOW
}

enum StatusOrderItem {
  COOKING
  READY
  SERVED
}
