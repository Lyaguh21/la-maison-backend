generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//? Пользователи

enum Role {
  ADMIN // Менеджер
  WAITER // Официант
  COOK // Повар
  CUSTOMER // Клиент
}

model User {
  id                 Int          @id @default(autoincrement())
  name               String?
  email              String       @unique
  phone              String?      @unique
  passwordHash       String
  hashedRefreshToken String?
  tokenVersion       Int          @default(0)
  role               Role         @default(CUSTOMER)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  userAllergens      Ingredient[] @relation("UserAllergens")
}

//? Ресторан

enum TableType {
  TWO
  FOUR
  SIX
}

model Tables {
  id         Int          @id @default(autoincrement())
  number     Int          @unique
  tableType  TableType
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  floorItems FloorItems[]
}

enum TypeFloorItems {
  TABLE
  WC
  EXIT
  BAR
}

model FloorItems {
  id        Int            @id @default(autoincrement())
  type      TypeFloorItems
  tableId   Int?
  table     Tables?        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  x         Int
  y         Int
  width     Int
  height    Int
  rotation  Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([tableId])
}

//? Меню

model MenuCategory {
  id     Int    @id @default(autoincrement())
  name   String @unique
  dishes Dish[]
}

model Ingredient {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  dishIngredients DishIngredient[]
  allergenUsers   User[]           @relation("UserAllergens")
}

model Dish {
  id         Int          @id @default(autoincrement())
  categoryId Int
  category   MenuCategory @relation(fields: [categoryId], references: [id])

  name        String   @unique
  description String?
  price       Float
  photo       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dishIngredients DishIngredient[]
  orderItems      OrderItem[]
}

model DishIngredient {
  dishId       Int
  ingredientId Int

  dish       Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([dishId, ingredientId])
}

//? Бронирования, посещения и заказы

enum StatusReservations {
  BOOKED
  SEATED
  CANCELLED
  PAID
  COMPLETED
  NO_SHOW
}

model Reservation {
  id          Int                @id @default(autoincrement())
  userId      Int?
  guestName   String?
  guestPhone  String?
  tableId     Int
  guestsCount Int
  status      StatusReservations @default(BOOKED)

  startTime     DateTime
  endTime       DateTime
  realStartTime DateTime?
  realEndTime   DateTime?

  waiterId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order[]
}

model Order {
  id            Int         @id @default(autoincrement())
  reservationId Int
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  totalPriceOrder Float
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[]
}

enum StatusOrderItem {
  COOKING
  READY
  SERVED
}

model OrderItem {
  id            Int             @id @default(autoincrement())
  orderId       Int
  dishId        Int
  comment       String?
  quantity      Int
  priceSnapshot Int
  status        StatusOrderItem @default(COOKING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  dish          Dish            @relation(fields: [dishId], references: [id])
  order         Order           @relation(fields: [orderId], references: [id])
}
